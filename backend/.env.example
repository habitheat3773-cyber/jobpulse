# ── JobPulse India Backend Environment Variables ──────────────────────────────
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobpulse_india

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Email (Gmail SMTP)
# For Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# Anthropic Claude API (for AI job description processing)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Optional: Telegram Bot (for Telegram alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@jobpulseindia
